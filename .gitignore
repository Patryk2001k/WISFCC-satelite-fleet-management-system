# Ignorowanie całego folderu eksportowego (z plikiem .tar)
/Export/

# Ignorowanie archiwów i paczek
*.tar
*.zip
*.rar

# JAVA (Spring Boot)
**/target/
**/.idea/
**/*.iml
**/.classpath
**/.project
**/.settings/
**/bin/
**/.factorypath

# PYTHON
**/__pycache__/
**/*.pyc
**/.venv/
**/venv/
**/.env
**/.pytest_cache/

# REACT (Node.js)
**/node_modules/
**/dist/
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/*.log